<Window x:Class="VolatileMemoHUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VolatileMemo"
        Width="520"
        Height="320"
        MinWidth="320"
        MinHeight="180"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Topmost="True"
        Visibility="Hidden"
        WindowStartupLocation="Manual"
        Background="Transparent">
    <Border Margin="0"
            Padding="8"
            Background="#F7F9FB"
            BorderBrush="#DCE6ED"
            BorderThickness="1"
            CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <!-- <RowDefinition Height="Auto" /> -->
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- <TextBlock Grid.Row="0"
                       Margin="0,0,0,6"
                       Text="揮発メモ"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#4E5D67" /> -->

            <TextBox x:Name="MemoTextBox"
                     Grid.Row="0"
                     Margin="0"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     FontSize="14"
                     BorderBrush="#CBD9E2"
                     BorderThickness="1"
                     Padding="10" />

            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Text="Ctrl+Enter: コピーして閉じる / Esc: 破棄"
                       FontSize="11"
                       Foreground="#6D7D88" />
        </Grid>
    </Border>
</Window>
